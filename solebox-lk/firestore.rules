rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net - default deny everything first
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Cost-optimized static admin check for O(1) list queries
    function isAdminStatic() {
      return isSignedIn() && (
        request.auth.token.email == "charakaviduranga2@gmail.com" 
        || request.auth.token.email == "soleboxlk@gmail.com"
      );
    }

    // Dynamic admin check for O(1) single documents
    function isAdmin() {
      return isAdminStatic() || (
        isSignedIn() && (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
          || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
        )
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. User entity schema validation
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'isAdmin'])
        && data.keys().size() >= 4
        && data.id == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 105
        && data.isAdmin is bool;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdminStatic() || isAdmin();
      allow create: if isSignedIn() && isValidUser(incoming()) && incoming().isAdmin == false;
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && isValidUser(incoming()) && incoming().isAdmin == existing().isAdmin && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email']))
        || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // 3. Admin reference schema validation
    function isValidAdmin(data) {
      return data.keys().hasAll(['uid', 'email'])
        && data.keys().size() >= 2
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 105;
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidAdmin(incoming());
    }

    // 4. Products schema validation (Only administrator can write, anyone can read)
    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'brand', 'price', 'sizes', 'description', 'image'])
        && data.keys().size() >= 7
        && data.id is string && data.id.size() <= 64
        && data.name is string && data.name.size() > 0 && data.name.size() <= 150
        && data.brand is string && data.brand.size() > 0 && data.brand.size() <= 100
        && (data.price is int || data.price is float) && data.price > 0
        && data.sizes is list && data.sizes.size() > 0 && data.sizes.size() <= 100
        && data.description is string && data.description.size() <= 1000
        && data.image is string && data.image.size() <= 1000;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // 5. Orders schema validation
    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'userId', 'userEmail', 'userName', 'items', 'total', 'date', 'status'])
        && data.keys().size() >= 8
        && data.id is string && data.id.size() <= 64
        && data.userId is string && data.userId.size() <= 128
        && data.userEmail is string && data.userEmail.size() <= 105
        && data.userName is string && data.userName.size() <= 100
        && data.items is list && data.items.size() > 0 && data.items.size() <= 100
        && (data.total is int || data.total is float) && data.total > 0
        && data.date is string && data.date.size() <= 32
        && data.status is string && (data.status == 'Pending' || data.status == 'Confirmed' || data.status == 'Shipped' || data.status == 'Delivered');
    }

    match /orders/{orderId} {
      allow create: if isSignedIn() && isValidOrder(incoming()) && (incoming().userId == request.auth.uid || isAdmin()) && incoming().status == 'Pending';
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminStatic() || isAdmin());
      allow update: if isSignedIn() && (
        isAdmin() && isValidOrder(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasAny(['status', 'courierTracking'])
        )
      );
      allow delete: if isAdmin();
    }
  }
}
